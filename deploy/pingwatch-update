#!/bin/bash
# Detached update runner. Started by the host-helper via systemd-run (own
# transient unit) so that restarting the helper or the app mid-update can
# NOT kill the update. Progress goes to /run/pingwatch-shared/
# update-result.json (read by the UI) and /tmp/pingwatch-update.log.
set -u

SHARED="/run/pingwatch-shared"
RESULT="${SHARED}/update-result.json"
LOGFILE="/tmp/pingwatch-update.log"

phase() {
  # $1 = phase (pull|install|restart|done|failed), $2 = short detail
  printf '{"ts_ms":%s,"phase":"%s","detail":"%s"}\n' \
    "$(date +%s)000" "$1" "$2" > "${RESULT}.tmp" 2>/dev/null \
    && chmod 644 "${RESULT}.tmp" && mv -f "${RESULT}.tmp" "$RESULT"
  logger -t pingwatch-update "phase=$1 $2"
}

: > "$LOGFILE" 2>/dev/null || LOGFILE=/dev/null

cd /opt/pingwatch || { phase failed "kein /opt/pingwatch"; exit 1; }

phase pull "hole neuen Stand"
if ! git pull --ff-only >>"$LOGFILE" 2>&1; then
  phase failed "git pull fehlgeschlagen (Log: /tmp/pingwatch-update.log)"
  exit 1
fi

phase install "Installer laeuft (Pakete + Image-Build, dauert 1-3 Min)"
if ! bash deploy/install-pingwatch.sh </dev/null >>"$LOGFILE" 2>&1; then
  phase failed "Installer fehlgeschlagen (Log: /tmp/pingwatch-update.log)"
  exit 1
fi

phase restart "Dienste starten neu"
systemctl restart pingwatch.service >>"$LOGFILE" 2>&1 || true
systemctl restart pingwatch-host-helper.service >>"$LOGFILE" 2>&1 || true

phase done "Update abgeschlossen"
